rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function teamPath(teamId) {
      return /databases/$(database)/documents/teams/$(teamId);
    }

    function teamExists(teamId) {
      return exists(teamPath(teamId));
    }

    function isTeamMember(teamId) {
      return signedIn()
        && teamExists(teamId)
        && request.auth.uid in get(teamPath(teamId)).data.memberUids;
    }

    function isTeamOwner(teamId) {
      return signedIn()
        && teamExists(teamId)
        && get(teamPath(teamId)).data.ownerUid == request.auth.uid;
    }

    match /users/{userId} {
      allow read, create, update, delete: if signedIn() && request.auth.uid == userId;
    }

    match /teams/{teamId} {
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.memberUids is list
        && request.auth.uid in request.resource.data.memberUids;

      allow read: if isTeamMember(teamId);
      allow update, delete: if isTeamOwner(teamId);

      match /state/{stateId} {
        allow read, create, update, delete: if isTeamMember(teamId);
      }
    }
  }
}
